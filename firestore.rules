rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "mitarbeiter") == "admin";
    }

    function isMitarbeiter() {
      return signedIn()
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "mitarbeiter") == "mitarbeiter"
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "mitarbeiter") == "admin");
    }

    function isOwner(fieldName) {
      return signedIn() && resource.data[fieldName] == request.auth.uid;
    }

    // ============ USERS ============
    match /users/{uid} {
      allow read: if signedIn();
      
      allow create: if signedIn() && request.auth.uid == uid;
      
      allow update: if signedIn() && (
        // Benutzer kann sein eigenes Profil aktualisieren (nur bestimmte Felder)
        request.auth.uid == uid 
        // Admin kann fremde Profile aktualisieren
        || (request.auth.uid != uid && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "") == "admin")
      );
      
      allow delete: if request.auth.uid != uid && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "") == "admin";
    }

    // ============ INVENTORY ============
    // items
    match /items/{itemId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // categories
    match /categories/{categoryId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // warehouses
    match /warehouses/{warehouseId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // logs
    match /logs/{logId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // ============ RESERVATIONS ============
    // active reservations
    match /reservations/{resId} {
      allow create: if signedIn();
      allow read: if isAdmin() || (signedIn() && resource.data.reservedByUid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if signedIn();
    }

    // reservation history
    match /reservation_history/{hid} {
      allow create: if signedIn();
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // buchungen (Bookings/Reservations legacy)
    match /buchungen/{buchungId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    // ============ REAL ESTATE / IMMOBILIEN ============
    
    // properties (Wohnungen/Objekte) - Mitarbeiter können alles verwalten
    match /properties/{propertyId} {
      allow read: if signedIn();
      allow create: if isMitarbeiter();
      allow update: if isMitarbeiter();
      allow delete: if isMitarbeiter();
    }

    // moveouts (Auszüge)
    match /moveouts/{moveoutId} {
      allow read: if signedIn();
      allow create: if isMitarbeiter();
      allow update, delete: if isMitarbeiter();
    }

    // auszuege (Auszüge - alternative collection)
    match /auszuege/{auszugId} {
      allow read: if signedIn();
      allow create: if isMitarbeiter();
      allow update, delete: if isMitarbeiter();
    }

    // moveins (Einzüge)
    match /moveins/{moveinId} {
      allow read: if signedIn();
      allow create: if isMitarbeiter();
      allow update, delete: if isMitarbeiter();
    }

    // electricity contracts
    match /electricityContracts/{contractId} {
      allow read: if signedIn();
      allow create: if isMitarbeiter();
      allow update, delete: if isMitarbeiter();
    }

    // water contracts
    match /waterContracts/{contractId} {
      allow read: if signedIn();
      allow create: if isMitarbeiter();
      allow update, delete: if isMitarbeiter();
    }

    // gas contracts
    match /gasContracts/{contractId} {
      allow read: if signedIn();
      allow create: if isMitarbeiter();
      allow update, delete: if isMitarbeiter();
    }

    // ============ SUPPORT & COMMUNICATION ============
    
    // Support Tickets
    match /supportTickets/{ticketId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    // Chat Messages
    match /chatMessages/{messageId} {
      allow read, write: if signedIn();
    }
    
    // key protocols (Schlüsselübergabe/Rückgabe)
    match /keyProtocols/{protocolId} {
      allow read: if signedIn();
      allow create: if isMitarbeiter();
      allow update, delete: if isMitarbeiter();
    }

    // ============ FUHRPARK / FLEET MANAGEMENT ============
    
    // vehicles (Fahrzeuge)
    match /vehicles/{vehicleId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin() || isOwner("createdByUid");
    }
  }
}
